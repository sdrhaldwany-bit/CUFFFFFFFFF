local g={Cuffed="\226\173\163 Cuffed",Drop="\240\159\146\128 DROP THEM",CuffAll="CUFF ALL",Uncuff="UNCUFF ALL",CuffOn="Cuff: ON",CuffOff="Cuff: OFF",Title="\240\159\154\128 DROP THEM",Count="Cuffed: "}

local RemoteEvents={}local CuffedTargets={}local CuffingActive=false local CuffingAllActive=false local Teleporting=false

local function UpdateRemoteEvents()
    RemoteEvents={}
    for _,plr in pairs(a:GetPlayers())do
        for _,tool in pairs(plr.Backpack:GetChildren())do
            local re=tool:FindFirstChildWhichIsA("RemoteEvent")
            if re then table.insert(RemoteEvents,re)end
        end
        if plr.Character then
            for _,tool in pairs(plr.Character:GetChildren())do
                local re=tool:FindFirstChildWhichIsA("RemoteEvent")
                if re then table.insert(RemoteEvents,re)end
            end
        end
    end
end

local function ShowStatus(plr,status)
    if not plr.Character then return end
    local hrp=plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local tag=hrp:FindFirstChild("StatusTag")
    if not tag then
        tag=Instance.new("BillboardGui")
        tag.Name="StatusTag"
        tag.Size=UDim2.new(0,100,0,50)
        tag.StudsOffset=Vector3.new(0,3,0)
        tag.AlwaysOnTop=true
        tag.Parent=hrp
        local label=Instance.new("TextLabel",tag)
        label.Size=UDim2.new(1,0,1,0)
        label.BackgroundTransparency=1
        label.TextScaled=true
        label.TextStrokeTransparency=0
        label.TextColor3=Color3.fromRGB(255,255,255)
        label.Name="Label"
    end
    local label=tag:FindFirstChild("Label")
    if label then
        if status=="Cuffed"then
            label.Text=g.Cuffed
            label.TextColor3=Color3.fromRGB(255,0,0)
        else
            label.Text=""
        end
    end
end

local function ToggleCuff(target)
    if not target or not target.Character then return end
    local hrp=target.Character:FindFirstChild("HumanoidRootPart")or target.Character:FindFirstChild("Torso")
    if not hrp then return end
    UpdateRemoteEvents()
    local idx=table.find(CuffedTargets,target)
    if idx then
        for _,re in pairs(RemoteEvents)do pcall(function()re:FireServer("UnCuff")end)end
        table.remove(CuffedTargets,idx)
        ShowStatus(target,nil)
    else
        for _,re in pairs(RemoteEvents)do pcall(function()re:FireServer("Cuff",hrp)end)end
        table.insert(CuffedTargets,target)
        ShowStatus(target,"Cuffed")
    end
end

local function CuffAllPlayers()
    if CuffingAllActive then return end
    CuffingAllActive=true
    local playersList={}
    for _,plr in pairs(a:GetPlayers())do
        if plr~=b and plr.Character then table.insert(playersList,plr)end
    end
    for _,plr in pairs(playersList)do
        if plr and plr.Character then
            local hrp=plr.Character:FindFirstChild("HumanoidRootPart")or plr.Character:FindFirstChild("Torso")
            if hrp then
                UpdateRemoteEvents()
                for _,re in pairs(RemoteEvents)do pcall(function()re:FireServer("Cuff",hrp)end)end
                if not table.find(CuffedTargets,plr)then
                    table.insert(CuffedTargets,plr)
                    ShowStatus(plr,"Cuffed")
                end
            end
        end
        task.wait()
    end
    CuffingAllActive=false
end

local function UncuffAllPlayers()
    UpdateRemoteEvents()
    for _,re in pairs(RemoteEvents)do pcall(function()re:FireServer("UnCuff")end)end
    for _,plr in pairs(CuffedTargets)do ShowStatus(plr,nil)end
    CuffedTargets={}
end

local function DropCuffedPlayers()
    if Teleporting then return end
    Teleporting=true
    local cuffedPlayers={}
    for _,plr in pairs(CuffedTargets)do
        if plr and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")then
            table.insert(cuffedPlayers,plr)
        end
    end
    if #cuffedPlayers==0 then Teleporting=false return end
    local myChar=b.Character
    local myHrp=myChar and myChar:FindFirstChild("HumanoidRootPart")
    local originalCF=myHrp and myHrp.CFrame or CFrame.new(0,5,0)
    local farPosition=CFrame.new(100000,500,100000)
    for _,plr in pairs(cuffedPlayers)do
        local hrp=plr.Character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame=farPosition end
    end
    if myHrp then myHrp.CFrame=farPosition end
    task.wait(0.05)
    for _,re in pairs(RemoteEvents)do pcall(function()re:FireServer("UnCuff")end)end
    for _,plr in pairs(cuffedPlayers)do ShowStatus(plr,nil)end
    CuffedTargets={}
    if myHrp then myHrp.CFrame=originalCF end
    Teleporting=false
end

